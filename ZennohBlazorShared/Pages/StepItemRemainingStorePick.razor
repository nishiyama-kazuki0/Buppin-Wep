@inherits StepItemBase

@*HT画面：出庫作業/倉庫別ピッキング/残格納（倉庫別）/残格納確定*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <div id=@STR_INIT_FOCUS_MARK tabindex="0" />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="ﾊﾟﾚｯﾄNo." Value="@(((StepItemRemainingStoreViewModel?)PageVm!).PalletNo)" IsMixed="@(((StepItemRemainingStoreViewModel?)PageVm)!.IsMixed)" />
@*             <HtTitleValueLabel Title="ﾋﾟｯｸ数:" Value="@(((StepItemRemainingStoreViewModel)PageVm!).Pick)"
                Title2="残数:" Value2="@(((StepItemRemainingStoreViewModel?)PageVm)!.Remain)" /> *@

            <HtTitleValueTextBoxCaseBara Title="ﾋﾟｯｸ\nｹｰｽ/ﾊﾞﾗ数"
                                         Value="@(((StepItemRemainingStoreViewModel)PageVm!).SijiCase)"
                                         Value2="@(((StepItemRemainingStoreViewModel)PageVm!).SijiBara)" />
            <HtTitleValueTextBoxCaseBara Title="残在庫\nｹｰｽ/ﾊﾞﾗ数"
                                         Value="@(((StepItemRemainingStoreViewModel)PageVm!).ZanCase)"
                                         Value2="@(((StepItemRemainingStoreViewModel)PageVm!).ZanBara)" />
            <HtTitleValueTextBox Id="SPalletNo" NextId="SPalletNo" Focus="true" Disabled="false" Title="先ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemRemainingStoreViewModel?)PageVm!).SPalletNo)" Change="@OnChangeSPalletNo"
                                 MaxLength="SharedConst.LEN_PALLET_NO" Required="true" RegexPattern="@SharedConst.STR_VARIDATE_PALLETE_NO" />

        </RadzenStack>
    </RadzenCard>

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px">
        <RadzenIcon Icon="view_list" />
        <RadzenText Text="倉庫配送先一覧" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" TagName="TagName.P" Style="margin-bottom: 0px"></RadzenText>
    </RadzenRow>

    <DataGridExtend2 @attributes="@(GetAttributes(STR_ATTRIBUTE_GRID))" />
</EditForm>

