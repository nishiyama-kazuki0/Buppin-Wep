@inherits StepItemBase

@*HT画面：在庫作業/パレット照会/パレット在庫明細 店別仕分在庫*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <div id=@STR_INIT_FOCUS_MARK tabindex="0" />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">
            <HtTitleValueTextBox Disabled="true" Title="ﾊﾟﾚｯﾄNo." Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).PalletNo)" IsMixed="@(((StepItemSortingByStorePalletInventoryInquiryViewModel?)PageVm)!.IsMixed)" />
        </RadzenStack>
    </RadzenCard>
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
        <RadzenIcon Icon="info"Style="margin-bottom:0px;" />
        <RadzenText Text="在庫明細" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left"Style="margin-bottom:0px;"></RadzenText>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="品名" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).ProductName)" />
            <HtTitleValueTextBox Title="入荷-明細\nNo." Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).ArrivalDetailNoShow)" />
            <HtTitleValueTextBox Title="等階級" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).GradeClass)" />
            <HtTitleValueTextBox Title="出荷者" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).Shipper)" />
            <HtTitleValueTextBox Title="産地" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).ProductArea)" />
            <HtTitleValueTextBox Title="荷姿" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).Packing)" />
            <HtTitleValueTextBox Title="入数" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).PackingQuantity)" />
            <HtTitleValueTextBox Title="荷印" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).PackingMark)" />
            <HtTitleValueTextBox Title="説明" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).Explanation)" />
            <HtTitleValueTextBox Title="特管品" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).SpecialType)" />
            <HtTitleValueTextBox Title="ｴﾁﾚﾝ" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).Ethylene)" />
            <HtTitleValueTextBox Title="温度帯" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).TempRange)" />
            <HtTitleValueTextBoxCaseBara Title="ｹｰｽ/ﾊﾞﾗ数" 
                Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).Case)" 
                Value2="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).Bara)" />
            <HtTitleValueTextBox Title="倉庫配送先\nｺｰﾄﾞ" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).DeliveryCd)" />
            <HtTitleValueTextBox Title="倉庫配送先" Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).DeliveryNm)" />
            <HtTitleValueTextBoxCaseBara Title="引当\nｹｰｽ/ﾊﾞﾗ数"
                Value="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).ApplyCase)"
                Value2="@(((StepItemSortingByStorePalletInventoryInquiryViewModel)PageVm!).ApplyBara)" />
        </RadzenStack>
    </RadzenCard>
</EditForm>
