@inherits StepItemBase

@*HT画面：入庫作業/パレット紐付/入荷-明細No.選択*@


<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueDropDown Id="ArrivalDetailNo" NextId="ArrivalDetailNo" Focus="true" Disabled="false" Title=@($"入荷-明細\nNo.") Data="@dropdownArrivalNo" @bind-Value="@(((StepItemStockupWorkPlansViewModel)PageVm!).ArrivalDetailNo)" Change="OnChangeArrivalNo" Required="true" />

        </RadzenStack>
    </RadzenCard>

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px">
        <RadzenIcon Icon="info" />
        <RadzenText Text="検品実績情報" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" TagName="TagName.P" Style="margin-bottom: 0px"></RadzenText>
    </RadzenRow>

    <DataCardList @ref="@cardLst" CardValues="@_cardValuesList" @bind-SelectedData="@_cardSelectedData" />
</EditForm>
