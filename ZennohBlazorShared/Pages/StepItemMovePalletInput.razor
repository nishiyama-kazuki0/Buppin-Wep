@inherits StepItemBase

@*HT画面：入庫作業/パレット移動/移動先入力*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />

        @*検索条件*@
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
            <RadzenIcon Icon="info" />
            <RadzenText Text="移動先入力" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left"Style="margin-bottom:0px;"></RadzenText>
        </RadzenRow>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

                <HtTitleValueTextBox Title="ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemMovePalletViewModel)PageVm!).PalletNo)" IsMixed="@(((StepItemMovePalletViewModel?)PageVm)!.IsMixed)" />
                <RadzenAlert Variant="Variant.Filled"
                             AlertStyle="AlertStyle.Warning"
                             Size="AlertSize.Small"
                             Shade="Shade.Light"
                             AllowClose=false
                             Title="@(((StepItemMovePalletViewModel?)PageVm)!.AlertTitle)"
                             Text="@(((StepItemMovePalletViewModel?)PageVm)!.AlertText)"
                             Visible="@(((StepItemMovePalletViewModel?)PageVm)!.IsAlert)" />
                <HtTitleValueDropDown Id="AreaCd" NextId="ZoneCd" Focus="true" Disabled="false" Title="倉庫" Data="@dropdownArea" @bind-Value="@(((StepItemMovePalletViewModel)PageVm!).AreaCd)" Change="@OnChangeArea" Required="true" />
            <HtTitleValueDropDown Id="ZoneCd"
                                  NextId=@(IsLocationTextEnable()
                                  ? "AreaCd":"LocationCd")
                                  Disabled="false" Title="ｿﾞｰﾝ" Data="@dropdownZone" @bind-Value="@(((StepItemMovePalletViewModel)PageVm!).ZoneCd)" Change="@OnChangeZone" Required="true" />
            @if (IsLocationTextEnable())
            {
                <HtTitleValueTextBox Title="棚番" Value="@(GetLocationName())" Id="LocationCd" Required="false" Disabled="true" IsDispRequiredMark　="true" />
            } 
            else
            {
                <HtTitleValueDropDown Id="LocationCd" NextId="AreaCd" Disabled="false" Title="棚番" Data="@dropdownLocation" @bind-Value="@(((StepItemMovePalletViewModel)PageVm!).LocationCd)" Change="@OnChangeLocation" Required="false" IsDispRequiredMark　="true"/>
            }

            </RadzenStack>
        </RadzenCard>

        @*</RadzenFieldset>*@
        @*上記で選択している倉庫、ゾーンによってDBから空きロケを取得し、変化させる*@
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
            <RadzenIcon Icon="info" />
            <RadzenText Text="推奨保管ﾛｹ" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left"Style="margin-bottom:0px;"></RadzenText>
        </RadzenRow>

        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

                <HtTitleValueTextBox Title="荷高:高" Value="@(((StepItemMovePalletViewModel)PageVm!).RecomLocationH)" />
                <HtTitleValueTextBox Title="荷高:中" Value="@(((StepItemMovePalletViewModel)PageVm!).RecomLocationM)" />
                <HtTitleValueTextBox Title="荷高:低" Value="@(((StepItemMovePalletViewModel)PageVm!).RecomLocationL)" />

            </RadzenStack>
        </RadzenCard>

        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
            <RadzenText Text="在庫情報" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left"Style="margin-bottom:0px;"></RadzenText>
        </RadzenRow>

        <DataCardList @ref="@cardLst" CardValues="@_cardValuesList" @bind-SelectedData="@_cardSelectedData"/>

</EditForm>
