@inherits StepItemBase

@*HT画面：出庫作業/倉庫配送先別ピッキング/残格納（倉庫配送先別）/残格納確定*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <div id=@STR_INIT_FOCUS_MARK tabindex="0" />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="ﾊﾟﾚｯﾄNo." Value="@(((StepItemRemainingStoreByDeliveryViewModel?)PageVm!).PalletNo)" IsMixed="@(((StepItemRemainingStoreByDeliveryViewModel?)PageVm)!.IsMixed)" />
@*             <HtTitleValueLabel Title="ﾋﾟｯｸ数:" Value="@(((StepItemRemainingStoreByDeliveryViewModel)PageVm!).Pick)"
                Title2="残数:" Value2="@(((StepItemRemainingStoreByDeliveryViewModel?)PageVm)!.Remain)" /> *@
            <HtTitleValueTextBoxCaseBara Title="ﾋﾟｯｸ\nｹｰｽ/ﾊﾞﾗ数"
                                         Value="@(((StepItemRemainingStoreByDeliveryViewModel)PageVm!).SijiCase)"
                                         Value2="@(((StepItemRemainingStoreByDeliveryViewModel)PageVm!).SijiBara)" />
            <HtTitleValueTextBoxCaseBara Title="残在庫\nｹｰｽ/ﾊﾞﾗ数"
                                         Value="@(((StepItemRemainingStoreByDeliveryViewModel)PageVm!).ZanCase)"
                                         Value2="@(((StepItemRemainingStoreByDeliveryViewModel)PageVm!).ZanBara)" />

            <HtTitleValueTextBox Id="SPalletNo" NextId="SPalletNo" Focus="true" Disabled="false" Title="先ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemRemainingStoreByDeliveryViewModel?)PageVm!).SPalletNo)" Change="@OnChangeSPalletNo"
                                 MaxLength="SharedConst.LEN_PALLET_NO" Required="true" RegexPattern="@SharedConst.STR_VARIDATE_PALLETE_NO" />
        </RadzenStack>
    </RadzenCard>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Start" Wrap="FlexWrap.NoWrap" Gap="0">
        <RadzenIcon Icon="view_list" />
        <RadzenText Text="倉庫配送先一覧" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left"></RadzenText>
    </RadzenStack>

    <DataGridExtend2 @attributes="@(GetAttributes(STR_ATTRIBUTE_GRID))" />
</EditForm>

