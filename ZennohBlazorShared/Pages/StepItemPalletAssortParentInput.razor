@inherits StepItemBase

@*HT画面：在庫作業/パレット詰合せ/親パレットNo.読取*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
        <RadzenIcon Icon="search"Style="margin-bottom:0px;" />
        <RadzenText Text="親ﾊﾟﾚｯﾄNo.入力" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left"Style="margin-bottom:0px;"></RadzenText>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Id="PPalletNo" NextId="PPalletNo" Focus="true" Disabled="false" Title="親ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemPalletAssortViewModel)PageVm!).PPalletNo)"
                                 MaxLength="SharedConst.LEN_PALLET_NO" Required="true" Change="@OnChangePalletNo" RegexPattern="@SharedConst.STR_VARIDATE_PALLETE_NO" />

        </RadzenStack>
    </RadzenCard>
</EditForm>
