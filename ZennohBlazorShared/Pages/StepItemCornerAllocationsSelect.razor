@inherits StepItemBase

@*HT画面：出庫作業/コーナー割付/コーナーパレットNo読取
*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">
            <HtTitleValueTextBox Id="PalletNo" NextId="PalletNo" Focus="true" Disabled="false" Title="ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemCornerAllocationsViewModel?)PageVm!).PalletNo)"
                Change="@OnChangePalletNo" MaxLength="@SharedConst.LEN_PALLET_NO" Required="true" Textnewline=true RegexPattern = "@SharedConst.STR_VARIDATE_PALLETE_NO" />
            </RadzenStack>
    </RadzenCard>
</EditForm>

