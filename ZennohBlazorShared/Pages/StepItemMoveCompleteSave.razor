@inherits StepItemBase

@*HT画面：出庫作業/切出搬送/切出先入力*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemMoveCompleteViewModel)PageVm!).PalletNo)" IsMixed="@(((StepItemMoveCompleteViewModel?)PageVm)!.IsMixed)"  />
            <HtTitleValueDropDown Id="AreaCd" NextId="ZoneCd" Focus="true" Disabled="false" Title="倉庫" Data="@dropdownArea" @bind-Value="@(((StepItemMoveCompleteViewModel)PageVm!).AreaCd)" Change="@OnChangeArea" Required="true" />
            <HtTitleValueDropDown Id="ZoneCd" NextId=@(IsLocationTextEnable()
                                  ? "AreaCd":"LocationCd")
                Disabled="false" Title="ｿﾞｰﾝ" Data="@dropdownZone" @bind-Value="@(((StepItemMoveCompleteViewModel)PageVm!).ZoneCd)" Change="@OnChangeZone" Required="true" />
            @if (IsLocationTextEnable())
            {
                <HtTitleValueTextBox Title="ﾛｹｰｼｮﾝ" Value="@(GetLocationName())" Id="LocationCd" Required="false" Disabled="true" IsDispRequiredMark　="true" />
            } 
            else
            {
                <HtTitleValueDropDown Id="LocationCd" NextId="AreaCd" Disabled="false" Title="ﾛｹｰｼｮﾝ" Data="@dropdownLocation" @bind-Value="@(((StepItemMoveCompleteViewModel)PageVm!).LocationCd)" Change="@OnChangeLocation" Required="false" IsDispRequiredMark　="true" />
            }
        </RadzenStack>
    </RadzenCard>

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px">
        <RadzenIcon Icon="info" />
        <RadzenText Text="ﾊﾟﾚｯﾄ現在位置" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" TagName="TagName.P" Style="margin-bottom: 0px"></RadzenText>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="現在倉庫" Value="@(((StepItemMoveCompleteViewModel)PageVm!).CurArea)" />
            <HtTitleValueTextBox Title="現在ｿﾞｰﾝ" Value="@(((StepItemMoveCompleteViewModel)PageVm!).CurZone)" />
            <HtTitleValueTextBox Title="現在ﾛｹ" Value="@(((StepItemMoveCompleteViewModel)PageVm!).CurLocation)" />

        </RadzenStack>
    </RadzenCard>
</EditForm>



