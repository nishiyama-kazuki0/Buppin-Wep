@inherits StepItemBase

@*HT画面：出庫作業/コーナー別仕分/コーナー仕分確定*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Id="SortingPalletNo" NextId="SortingPalletNo" Focus="true" Disabled="false" Title="ｺｰﾅｰ\nﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemSortingByCornersViewModel)PageVm!).SortingPalletNo)" Change="OnChangeSortingPalletNo" MaxLength="SharedConst.LEN_PALLET_NO" Required="true" RegexPattern="@SharedConst.STR_VARIDATE_PALLETE_NO" />
            <HtTitleValueTextBox Title="倉庫配送先" Value="@(((StepItemSortingByCornersViewModel)PageVm!).SortingDelivery)" />
            <HtTitleValueTextBox Title="ｺｰﾅｰ" Value="@(((StepItemSortingByCornersViewModel)PageVm!).SortingCorner)" />

        </RadzenStack>
    </RadzenCard>

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px">
        <RadzenIcon Icon="info" />
        <RadzenText Text="入力仕分情報" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" TagName="TagName.P" Style="margin-bottom: 0px"></RadzenText>
    </RadzenRow>
            
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Disabled="true" Title="品名" Value="@(((StepItemSortingByCornersViewModel)PageVm!).ProductName)" />
            <HtTitleValueTextBox Disabled="true" Title="倉庫配送先\nｺｰﾄﾞ" Value="@(((StepItemSortingByCornersViewModel)PageVm!).DeliveryCode)" />
            <HtTitleValueTextBox Disabled="true" Title="倉庫配送先" Value="@(((StepItemSortingByCornersViewModel)PageVm!).Delivery)" />
            @if (((StepItemSortingByCornersViewModel)PageVm!).ProcPlantFlag == "1")
            {
                <HtTitleValueTextBox Disabled="true" Title="加工場ｺｰﾄﾞ" Value="@(((StepItemSortingByCornersViewModel)PageVm!).ProcPlantCode)" />
                <HtTitleValueTextBox Disabled="true" Title="加工場名" Value="@(((StepItemSortingByCornersViewModel)PageVm!).ProcPlantName)" />
            }
            <HtTitleValueTextBox Disabled="true" Title="ｺｰﾅｰ" Value="@(((StepItemSortingByCornersViewModel)PageVm!).Corner)" />
            <HtTitleValueTextBox Disabled="true" Title="入荷-明細\nNo." Value="@(((StepItemSortingByCornersViewModel)PageVm!).ArrivalNo)" />
            <HtTitleValueTextBox Disabled="true" Title="等階級" Value="@(((StepItemSortingByCornersViewModel)PageVm!).GradeClass)" />
            <HtTitleValueTextBox Disabled="true" Title="出荷者" Value="@(((StepItemSortingByCornersViewModel)PageVm!).Shipper)" />
            <HtTitleValueTextBox Disabled="true" Title="産地" Value="@(((StepItemSortingByCornersViewModel)PageVm!).ProductArea)" />
            <HtTitleValueTextBox Disabled="true" Title="荷姿" Value="@(((StepItemSortingByCornersViewModel)PageVm!).Packing)" />
            <HtTitleValueTextBox Disabled="true" Title="入数" Value="@(((StepItemSortingByCornersViewModel)PageVm!).PackingQuantity)" />
            <HtTitleValueTextBoxCaseBara Title="仕分入力\nｹｰｽ/ﾊﾞﾗ数"
                Value="@(((StepItemSortingByCornersViewModel)PageVm!).SortingCase)" 
                Value2="@(((StepItemSortingByCornersViewModel)PageVm!).SortingBara)" />
            <HtTitleValueTextBoxCaseBara Title="引当済\nｹｰｽ/ﾊﾞﾗ数"
                Value="@(((StepItemSortingByCornersViewModel)PageVm!).ApplyCase)" 
                Value2="@(((StepItemSortingByCornersViewModel)PageVm!).ApplyBara)" />
            <HtTitleValueTextBox Disabled="true" Title="荷印" Value="@(((StepItemSortingByCornersViewModel)PageVm!).PackingMark)" />
            <HtTitleValueTextBox Disabled="true" Title="説明" Value="@(((StepItemSortingByCornersViewModel)PageVm!).Explanation)" />
            <HtTitleValueTextBox Disabled="true" Title="摘要" Value="@(((StepItemSortingByCornersViewModel)PageVm!).Remark)" />

        </RadzenStack>
    </RadzenCard>
</EditForm>
