@inherits StepItemBase

@*HT画面：出庫作業/倉庫配送先別ピッキング/パレットピック（倉庫配送先別）/パレットNo.読取*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">
            <HtTitleValueTextBox Title="倉庫配送\nｺｰﾄﾞ" Value="@(((StepItemPickingPalletByDeliveryViewModel)PageVm!).DeliveryCdTwoLineTitle)" IsZeroSuppress = "true"/>
            <HtTitleValueTextBox Title="倉庫配送先" Value="@(((StepItemPickingPalletByDeliveryViewModel)PageVm!).DeliveryName)" />
            <HtTitleValueTextBox Id="PalletNo" NextId="PalletNo" Focus="true" Disabled="false" Title="ﾊﾟﾚｯﾄNo." @bind-Value="@(((StepItemPickingPalletByDeliveryViewModel?)PageVm!).PalletNo)" Change="@OnChangePalletNo"
                                 MaxLength="SharedConst.LEN_PALLET_NO" Required="true" RegexPattern="@SharedConst.STR_VARIDATE_PALLETE_NO" />

        </RadzenStack>
    </RadzenCard>
</EditForm>

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px">
        <RadzenIcon Icon="view_list" />
        <RadzenText Text="ﾋﾟｯｸ予定一覧" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" TagName="TagName.P" Style="margin-bottom: 0px"></RadzenText>
    </RadzenRow>

<DataGridExtend2 @attributes="@(GetAttributes(STR_ATTRIBUTE_GRID))" OnCellRenderCallback="@CellRender" IsHandyGridSelect="true" @ref="@dataGrid" />

