@inherits StepItemBase

@*HT画面：出庫作業/コーナー搬送/コーナー搬送完了*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <div id=@STR_INIT_FOCUS_MARK tabindex="0" />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="ﾊﾟﾚｯﾄNo." Value="@(((StepItemMoveCompleteCornerViewModel?)PageVm!).PalletNo)" IsMixed="@(((StepItemMoveCompleteCornerViewModel?)PageVm)!.IsMixed)" Textnewline=true />
            <HtTitleValueTextBox Title=@($"倉庫配送先\nｺｰﾄﾞ") Value="@(((StepItemMoveCompleteCornerViewModel?)PageVm!).DeliveryNo )" Textnewline=true />
            <HtTitleValueTextBox Title="倉庫配送先" Value="@(((StepItemMoveCompleteCornerViewModel?)PageVm!).Delivery )" Textnewline=true />
            @if (((StepItemMoveCompleteCornerViewModel)PageVm!).ProcPlantFlag == "1")
            {
                <HtTitleValueTextBox Disabled="true" Title="加工場ｺｰﾄﾞ" Value="@(((StepItemMoveCompleteCornerViewModel)PageVm!).ProcPlantNo)" Textnewline=true />
                <HtTitleValueTextBox Disabled="true" Title="加工場名" Value="@(((StepItemMoveCompleteCornerViewModel)PageVm!).ProcPlantName)" Textnewline=true />
            }
            <HtTitleValueTextBox Title="向け先ｺｰﾅｰ" Value="@(((StepItemMoveCompleteCornerViewModel?)PageVm!).Corner)" Textnewline=true />

        </RadzenStack>
    </RadzenCard>
</EditForm>        
