@inherits StepItemBase

@*HT画面：店別仕分【種まき】/納品先選択*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <div id=@STR_INIT_FOCUS_MARK tabindex="0" />
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
        <RadzenIcon Icon="info" Style="margin-bottom:0px;"/>
        <RadzenText Text="入力情報" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" Style="margin-bottom:0px;"></RadzenText>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Disabled="true" Title="ﾊﾟﾚｯﾄNo" Value="@(((StepItemSortingByStoreViewModel)PageVm!).PalletNo)" />
            <HtTitleValueTextBox Disabled="true" Title="品名" Value="@(((StepItemSortingByStoreViewModel)PageVm!).ProductName)" />
            <HtTitleValueTextBox Disabled="true" Title="等階級" Value="@(((StepItemSortingByStoreViewModel)PageVm!).GradeClass)" />

        </RadzenStack>
    </RadzenCard>


    @*仕分け情報の表示*@

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px" >
        <RadzenIcon Icon="view_list"/>
        <RadzenText Text="納品先選択" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" Style="margin-bottom:0px;"></RadzenText>
    </RadzenRow>

    <DataGridExtend2 IsHandyGridSelect="true" @ref="@dataGrid" @attributes="@(GetAttributes(STR_ATTRIBUTE_GRID))" @bind-SelectedData="@_gridSelectedData" />
</EditForm>
