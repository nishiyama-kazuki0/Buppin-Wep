@inherits StepItemBase

@*HT画面：出庫作業/倉庫別ピッキング/パレットピッキング/ゾーン選択*@

<EditForm Model="@this" @ref="@editForm">
    <ValidationSummary style=@($"{ChildBaseService.StyleValidationSammary}") />
    <div id=@STR_INIT_FOCUS_MARK tabindex="0" />
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" JustifyContent="JustifyContent.Start" Wrap="FlexWrap.NoWrap" Gap="5">

            <HtTitleValueTextBox Title="倉庫" Value="@(((StepItemPickingTargetSelectViewModel?)PageVm!).AreaNm)" />

        </RadzenStack>
    </RadzenCard>
                    
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" RowGap="0" Gap="1px">
        <RadzenIcon Icon="view_list" />
        <RadzenText Text="ゾーン一覧" TextStyle="TextStyle.Subtitle2" TextAlign="TextAlign.Left" TagName="TagName.P" Style="margin-bottom: 0px"></RadzenText>
    </RadzenRow>

    <DataGridExtend2 IsHandyGridSelect="true" @ref="@dataGrid" @attributes="@(GetAttributes(STR_ATTRIBUTE_GRID))" @bind-SelectedData="@_gridSelectedData" />
</EditForm>

